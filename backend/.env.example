# MongoDB Connection URI (Atlas recommended for production)
MONGODB_URI=mongodb+srv://admin:yourpassword@cluster.mongodb.net/english-lms?retryWrites=true&w=majority

# App Configuration
PORT=5000
NODE_ENV=production

# Security
# Generate a strong secret with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_change_me
JWT_EXPIRES_IN=30d

# Frontend URL (for CORS protection)
# Can be a comma-separated list of URLs
CLIENT_URL=https://your-app.vercel.app,http://localhost:3000

# File Upload Limits (in bytes)
# Default: 100MB for videos
MAX_VIDEO_SIZE=104857600
